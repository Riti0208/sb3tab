# ESP32-P4 Scratcher configuration
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_COMPILER_CXX_EXCEPTIONS=y
CONFIG_SPIRAM=y

# Console disabled - G37(TX)/G38(RX) used for LCD SPI
# Debug output via usb_ll_write() on USB Serial/JTAG
CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# Main task needs large stack for ZIP/JSON parsing
CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768

# PSRAM speed for MIPI DSI framebuffer bandwidth
CONFIG_SPIRAM_SPEED_200M=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
