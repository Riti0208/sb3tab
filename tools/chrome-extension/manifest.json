{
  "manifest_version": 3,
  "name": "sb3tab QR",
  "version": "1.0",
  "description": "Generate QR codes (WiFi + Scratch project) for sb3tab on M5Stack Tab5 (ESP32-P4)",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
