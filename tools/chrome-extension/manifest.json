{
  "manifest_version": 3,
  "name": "Scratcher QR",
  "version": "1.0",
  "description": "Generate QR code for Scratch projects to load on ESP32-P4 Tab5",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
